{
  "name": "projectinator",
  "version": "0.1.0",
  "description": "Multi-LLM app-building pipeline — routes Scrum tasks to the best model per job. Phase 1: registry + router + cost estimator.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "tsx src/tui.tsx",
    "demo": "tsx src/demo.ts",
    "dev:task": "tsx src/run-dev.ts",
    "pm": "tsx src/run-pm.ts",
    "build": "tsx src/run-build.ts",
    "scout": "tsx src/run-scout.ts",
    "research": "tsx src/run-research.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@inkjs/ui": "^2.0.0",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.7",
    "typebox": "^1.1.38"
  }
}
